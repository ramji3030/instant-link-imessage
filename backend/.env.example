# Backend Configuration
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://dev:devpass@localhost:5432/instant_link

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE_IN=7d

# API Configuration
API_VERSION=v1
FRONTEND_URL=http://localhost:3000

# External Services
AI_MODEL_ENDPOINT=https://api.openai.com/v1
AI_MODEL_API_KEY=your_openai_api_key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# AWS (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=instant-link-uploads

# Logging
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_url

# Feature Flags
ENABLE_ML_MATCHING=true
ENABLE_EPHEMERAL_ROOMS=false
MAX_USERS_PER_ROOM=100
